<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>BibleBits</title>
  <style>
    body { margin: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; display: flex; align-items: center; justify-content: center; min-height: 100vh; background: #f5f5f5; }
    .msg { text-align: center; color: #555; font-size: 16px; }
    .msg strong { display: block; font-size: 22px; color: #222; margin-bottom: 8px; }
  </style>
</head>
<body>
  <div class="msg">
    <strong>BibleBits</strong>
    Redirecting you now...
  </div>
  <script>
    (function() {
      var ua = navigator.userAgent || navigator.vendor || window.opera;
      var ios = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;
      var android = /android/i.test(ua);
 
      if (ios) {
        // Replace APP_STORE_URL_HERE with your App Store link once Apple approves your app
        window.location.replace('APP_STORE_URL_HERE');
      } else if (android) {
        window.location.replace('https://play.google.com/store/apps/details?id=com.kerygmacode.biblebits&utm_source=na_Med');
      } else {
        window.location.replace('https://kerygmacode.com/');
      }
    })();
  </script>
</body>
</html>
